-- ================= COMMAND HANDLER =================
local function handle(player, msg)
	if player.Name ~= getgenv().OWNER then return end

	local args = string.split(msg, " ")
	local cmd = args[1]:lower()

	if cmd == getgenv().PREFIX.."follow" then
		following = true
		orbiting = false
		targetPlayer = player

	elseif cmd == getgenv().PREFIX.."orbit" then
		orbiting = true
		following = false
		targetPlayer = player

	elseif cmd == getgenv().PREFIX.."stop" then
		following = false
		orbiting = false
		targetPlayer = nil

	elseif cmd == getgenv().PREFIX.."say" then
		table.remove(args, 1)
		say(table.concat(args, " "))

	elseif cmd == getgenv().PREFIX.."god" then
		godmode()

	elseif cmd == getgenv().PREFIX.."cook" then
		bringFoodtoCamp()

	elseif cmd == getgenv().PREFIX.."loot" then
		for _, item in ipairs(workspace.Items:GetChildren()) do
			if string.find(item.Name, "Chest") then
				handleChest(item)
			end
		end

	elseif cmd == getgenv().PREFIX.."bring" then
		table.remove(args, 1)

		local itemName = table.concat(args, " ")
		if itemName ~= "" then
			bringItemsByName(itemName)
		end

	elseif cmd == getgenv().PREFIX.."hammer" then
		local vim = game:GetService("VirtualInputManager")

		vim:SendKeyEvent(true, Enum.KeyCode.Three, false, game)
		task.wait(0.05)
		vim:SendKeyEvent(false, Enum.KeyCode.Three, false, game)

		task.wait(0.1)

		vim:SendKeyEvent(true, Enum.KeyCode.Backspace, false, game)
		task.wait(0.05)
		vim:SendKeyEvent(false, Enum.KeyCode.Backspace, false, game)

	elseif cmd == getgenv().PREFIX.."fuel" then
		bringFuel = not bringFuel

		if bringFuel then
			runBringFuel()
		end

	elseif cmd == getgenv().PREFIX.."tree" then
		autoChop = not autoChop

		if autoChop then
			autochoptree()
			say("Auto Chop: ON")
		else
			say("Auto Chop: OFF")
		end

	elseif cmd == getgenv().PREFIX.."scrap" then
		bringMetal = not bringMetal

		if bringMetal then
			runBringMetal()
		end

	elseif cmd == getgenv().PREFIX.."aura" then
		auraEnabled = not auraEnabled

		if auraEnabled then
			killaura()
			say("Kill Aura: ON")
		else
			say("Kill Aura: OFF")
		end
	elseif cmd == getgenv().PREFIX.."tools" then
		bringToolsOnce()

	elseif cmd == getgenv().PREFIX.."strongaxe" then
		strong()
	end
end

