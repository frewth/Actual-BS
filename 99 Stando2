local function bringItemsByName(searchName)
	local character = lp.Character or lp.CharacterAdded:Wait()
	local hrp = character:WaitForChild("HumanoidRootPart")

	local lootToHandle = {}
	local search = string.lower(searchName)

	-- MATCH ITEMS (case-insensitive, partial match)
	for _, item in ipairs(workspace.Items:GetChildren()) do
		if item:IsA("Model") and item.PrimaryPart then
			if string.find(string.lower(item.Name), search) then
				table.insert(lootToHandle, item)
			end
		end
	end

	-- START DRAG ALL
	local startTime = tick()
	for _, loot in ipairs(lootToHandle) do
		pcall(function()
			requestDrag:FireServer(loot)
		end)
	end

	local elapsed = tick() - startTime
	if elapsed < 0.1 then
		task.wait(0.1 - elapsed)
	end

	-- MOVE ALL TO PLAYER
	for _, loot in ipairs(lootToHandle) do
		pcall(function()
			loot:PivotTo(hrp.CFrame * CFrame.new(0, 5, 0))
		end)
	end

	-- STOP DRAG ALL
	for _, loot in ipairs(lootToHandle) do
		pcall(function()
			stopDrag:FireServer(loot)
		end)
	end
end

