-- ================= AUTO CHOP (MULTI TREE) =================
local function getTreeKey(tree)
	return tostring(tree:GetDebugId())
end

local function cleanupTrees()
	for key, _ in pairs(treeHitCount) do
		local exists = false

		if workspace:FindFirstChild("Map") then
			for _, folder in pairs({workspace.Map.Foliage, workspace.Map.Landmarks}) do
				if folder then
					for _, tree in pairs(folder:GetChildren()) do
						if tostring(tree:GetDebugId()) == key then
							exists = true
							break
						end
					end
				end
			end
		end

		if not exists then
			treeHitCount[key] = nil
		end
	end
end

local function autochoptree()
	local LocalPlayer = Players.LocalPlayer
	local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
	local vim = game:GetService("VirtualInputManager")

	vim:SendKeyEvent(true, Enum.KeyCode.One, false, game)
	task.wait(0.05)
	vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)

	task.wait(0.1)

	vim:SendKeyEvent(true, Enum.KeyCode.Two, false, game)
	task.wait(0.05)
	vim:SendKeyEvent(false, Enum.KeyCode.Two, false, game)
	task.spawn(function()
		while autoChop do
			local LocalPlayer = Players.LocalPlayer
			local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
			local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

			local valueAxe = "1_" .. LocalPlayer.UserId

			-- Axe priority
			local axePriority = {
				"Strong Axe",
				"Good Axe",
				"Old Axe"
			}

			local function getBestAxe()
				local inventory = LocalPlayer:WaitForChild("Inventory")

				for _, axeName in ipairs(axePriority) do
					local axe = inventory:FindFirstChild(axeName)
					if axe then
						return axe
					end
				end

				return nil
			end

			-- Tree detection based on axe
			local function isValidTree(tree, axeName)
				if axeName == "Strong Axe" then
					return tree.Name == "TreeBig1" or tree.Name == "TreeBig2" or tree.Name == "Small Tree"
				elseif axeName == "Good Axe" or axeName == "Old Axe" then
					return tree.Name == "Small Tree"
				end
				return false
			end

			while task.wait(0.75) do
				local axe = getBestAxe()
				if not axe then continue end

				for _, v in ipairs(workspace.Map.Foliage:GetChildren()) do
					if v:FindFirstChild("Trunk") and isValidTree(v, axe.Name) then
						local trunk = v.Trunk

						if (HumanoidRootPart.Position - trunk.Position).Magnitude < getgenv().TREE_RANGE then
							rs.RemoteEvents.ToolDamageObject:InvokeServer(
								v,
								axe,
								valueAxe,
								HumanoidRootPart.CFrame
							)
						end
					end
				end
			end
			task.wait(.25)
		end
	end)
end

local Players = game:GetService("Players")
