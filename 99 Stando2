local function runBringFuel()
	local campfire = workspace.Map.Campground:FindFirstChild("MainFire")
	task.spawn(function()
		while bringFuel do
			local character = lp.Character or lp.CharacterAdded:Wait()
			local hrp = character:WaitForChild("HumanoidRootPart")

			local lootToHandle = {}

			-- COLLECT ALL VALID ITEMS
			for _, item in ipairs(workspace.Items:GetChildren()) do
				if item:IsA("Model") and item.PrimaryPart and targetFuel[item.Name] then
					table.insert(lootToHandle, item)
				end
