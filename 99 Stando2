-- Settings
local hitCount = 0
-- Remote
local Remote = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("ToolDamageObject")

local TOOL_PRIORITY = {
	"Strong Axe",
	"Good Axe",
	"Old Axe"
}

local function getTool()
	local inventory = LocalPlayer:WaitForChild("Inventory")

	for _, name in ipairs(TOOL_PRIORITY) do
		local tool = inventory:FindFirstChild(name)
		if tool then
			return tool
		end
	end

	return nil
end

-- Damage function
local function damage(target, tool)
	if not tool then return end

	local root = target:FindFirstChild("HumanoidRootPart")
	if not root then return end

	hitCount += 1

	Remote:InvokeServer(
		target,
		tool,
		tostring(hitCount) .. LocalPlayer.UserId,
		root.CFrame
	)
end

local function killaura()
	local vim = game:GetService("VirtualInputManager")

	vim:SendKeyEvent(true, Enum.KeyCode.One, false, game)
	task.wait(0.05)
	vim:SendKeyEvent(false, Enum.KeyCode.One, false, game)

	task.wait(0.1)

	vim:SendKeyEvent(true, Enum.KeyCode.Two, false, game)
	task.wait(0.05)
	vim:SendKeyEvent(false, Enum.KeyCode.Two, false, game)
	while auraEnabled do
		task.wait(0.15)

		local character = LocalPlayer.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		local tool = getTool()

		if not root or not tool then continue end

		for _, target in ipairs(Characters:GetChildren()) do
			if target ~= character and target:IsA("Model") then
				local targetRoot = target:FindFirstChild("HumanoidRootPart")

				if targetRoot then
					local distance = (targetRoot.Position - root.Position).Magnitude

					if distance <= getgenv().KILL_RANGE then
						damage(target, tool)
					end
				end
			end	
		end
	end
end

local function bringFoodtoCamp()
	local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local campfire = workspace.Map.Campground:FindFirstChild("MainFire")
	if not campfire or not campfire.PrimaryPart then
		return
	end

	for _, item in ipairs(workspace.Items:GetChildren()) do
		if item:IsA("Model") and item.PrimaryPart and 
			(string.find(item.Name, "Morsel") or string.find(item.Name, "Steak")) and
			not string.find(item.Name, "Cooked") then

			game.ReplicatedStorage.RemoteEvents.RequestStartDraggingItem:FireServer(item)

			local targetCFrame = campfire.PrimaryPart.CFrame * CFrame.new(0, 8, 0)
			item:PivotTo(targetCFrame)
			task.wait(.5)
			item:PivotTo(campfire.PrimaryPart.CFrame * CFrame.new(0, 0, 5))

			game.ReplicatedStorage.RemoteEvents.StopDraggingItem:FireServer(item)
			item:Destroy()
		end
	end
end
